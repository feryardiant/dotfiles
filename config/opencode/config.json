{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-3-flash-preview",
  "mcp": {
    "mcp-server-context7": {
      "type": "local",
      "enabled": true,
      "command": [
        "context7-mcp"
      ]
    },
    "mcp-server-sequential-thinking": {
      "type": "local",
      "enabled": true,
      "command": [
        "mcp-server-sequential-thinking"
      ]
    },
    "mcp-server-everything": {
      "type": "local",
      "enabled": true,
      "command": [
        "mcp-server-everything"
      ]
    },
    "mcp-shadcn": {
      "type": "local",
      "enabled": true,
      "command": [
        "shadcn-mcp"
      ]
    },
    "chrome-devtools": {
      "type": "local",
      "enabled": true,
      "command": ["chrome-devtools-mcp"]
    }
  },
  "provider": {
    "openrouter": {
      "models": {
        "deepseek/deepseek-r1:free": {},
        "qwen/qwen3-coder:free": {}
      }
    }
  }
}
